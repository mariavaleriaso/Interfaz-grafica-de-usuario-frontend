          <button type="button" class="link-btn" onclick="goToScreen('screen-login')">Iniciar sesión</button>
        </p>

      </section>

      <!-- ======================================================
           PANTALLA 3: RECUPERACIÓN DE CONTRASEÑA
      ====================================================== -->
      <section class="screen" id="screen-recovery" aria-label="Recuperar contraseña">

        <button type="button" class="back-link" onclick="goToScreen('screen-login')" aria-label="Volver al inicio de sesión">
          ← Volver
        </button>

        <div class="form-header">
          <p class="form-eyebrow">Acceso seguro</p>
          <h2 class="form-title">Recuperar contraseña</h2>
          <p class="form-subtitle">
            Ingresa tu correo y te enviaremos un enlace para restablecer tu contraseña.
          </p>
        </div>

        <!-- Alerta de error -->
        <div class="alert" id="recovery-alert" role="alert"></div>

        <form id="recovery-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="recovery-email">Correo electrónico</label>
            <input
              class="form-input"
              type="email"
              id="recovery-email"
              name="email"
              placeholder="analista@empresa.com"
              autocomplete="email"
              aria-describedby="recovery-email-error"
            />
            <span class="form-error" id="recovery-email-error" role="alert"></span>
          </div>

          <button type="submit" class="btn-primary" id="recovery-submit-btn">
            Enviar enlace
          </button>
        </form>

        <!-- Mensaje de confirmación (oculto hasta el envío) -->
        <div class="success-box" id="recovery-success" role="status" aria-live="polite">
          <div class="success-icon" aria-hidden="true">✉️</div>
          <p>
            <strong>Enlace enviado.</strong><br>
            Revisa tu bandeja de entrada y sigue las instrucciones para restablecer tu contraseña.
            El enlace expira en 15 minutos.
          </p>
        </div>

        <p class="form-footer" style="margin-top: 16px;">
          ¿Recordaste tu contraseña?
          <button type="button" class="link-btn" onclick="goToScreen('screen-login')">Volver al inicio</button>
        </p>

      </section>

    </div><!-- /.auth-card -->
  </main>

</div><!-- /.page-wrapper -->

<!-- ============================================================
     JAVASCRIPT — Lógica de autenticación y navegación
============================================================ -->
<script>
  /* ============================================================
     NAVEGACIÓN ENTRE PANTALLAS
     Gestiona la transición suave entre las tres vistas de autenticación
  ============================================================ */
  function goToScreen(targetId) {
    // Ocultar pantalla activa
    const current = document.querySelector('.screen.active');
    if (current) {
      current.style.opacity = '0';
      current.style.transform = 'translateY(12px)';

      setTimeout(() => {
        current.classList.remove('active');
        current.style.opacity = '';
        current.style.transform = '';

        // Mostrar pantalla destino
        const target = document.getElementById(targetId);
        if (target) {
          target.classList.add('active');
          // Forzar reflow para que la transición de entrada funcione
          void target.offsetWidth;
          target.style.opacity = '1';
          target.style.transform = 'translateY(0)';
          // Enfocar el primer campo del formulario para accesibilidad
          const firstInput = target.querySelector('input, button');
          if (firstInput) firstInput.focus();
        }
      }, 220);
    }

    // Limpiar alertas y errores al cambiar de pantalla
    clearAllErrors();
  }

  /* ============================================================
     VALIDACIONES GENERALES
  ============================================================ */

  // Valida que un campo no esté vacío
  function validateRequired(fieldId, errorId, message) {
    const field  = document.getElementById(fieldId);
    const error  = document.getElementById(errorId);
    const isEmpty = field.value.trim() === '';
    field.classList.toggle('error', isEmpty);
    error.textContent = isEmpty ? message : '';
    error.classList.toggle('visible', isEmpty);
    return !isEmpty;
  }

  // Valida formato de email con regex estándar
  function validateEmail(fieldId, errorId) {
    const field = document.getElementById(fieldId);
    const error = document.getElementById(errorId);
    const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    let msg = '';
    if (field.value.trim() === '') {
      msg = 'El correo electrónico es obligatorio.';
    } else if (!EMAIL_REGEX.test(field.value.trim())) {
      msg = 'Ingresa un correo electrónico válido (ej: nombre@empresa.com).';
    }
    const hasError = msg !== '';
    field.classList.toggle('error', hasError);
    error.textContent = msg;
    error.classList.toggle('visible', hasError);
    return !hasError;
  }

  // Muestra un mensaje de error en un campo específico
  function showFieldError(fieldId, errorId, message) {
    const field = document.getElementById(fieldId);
    const error = document.getElementById(errorId);
    field.classList.add('error');
    error.textContent = message;
    error.classList.add('visible');
  }

  // Limpia todos los errores en la página
  function clearAllErrors() {
    document.querySelectorAll('.form-error').forEach(el => {
      el.textContent = '';
      el.classList.remove('visible');
    });
    document.querySelectorAll('.form-input.error, .form-select.error').forEach(el => {
      el.classList.remove('error');
    });
    document.querySelectorAll('.alert').forEach(el => {
      el.className = 'alert';
      el.textContent = '';
    });
  }

  // Muestra alerta global en un formulario
  function showAlert(alertId, message, type = 'error') {
    const alert = document.getElementById(alertId);
    alert.className = 'alert ' + type;
    alert.textContent = message;
  }

  /* ============================================================
     TOGGLE DE VISIBILIDAD DE CONTRASEÑA
     Alterna entre type="password" y type="text"
  ============================================================ */
  function togglePassword(inputId, btn) {
    const input = document.getElementById(inputId);
    const eyeIcon = btn.querySelector('svg');
    const isHidden = input.type === 'password';

    input.type = isHidden ? 'text' : 'password';

    // Actualiza el ícono del ojo (abierto / tachado)
    if (isHidden) {
      // Ojo tachado (contraseña visible)
      eyeIcon.innerHTML = `
        <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/>
        <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      `;
    } else {
      // Ojo abierto (contraseña oculta)
      eyeIcon.innerHTML = `
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      `;
    }
    btn.setAttribute('aria-label', isHidden ? 'Ocultar contraseña' : 'Mostrar contraseña');
  }

  /* ============================================================
     BARRA DE FORTALEZA DE CONTRASEÑA
     Calcula y muestra el nivel de seguridad de la contraseña ingresada
  ============================================================ */
  function checkPasswordStrength(password) {
    const bar   = document.getElementById('strength-bar');
    const label = document.getElementById('strength-label');

    if (!password) {
      bar.className = 'strength-bar';
      label.textContent = '';
      return;
    }

    let score = 0;
    if (password.length >= 8)                          score++;
    if (/[A-Z]/.test(password) && /[a-z]/.test(password)) score++;
    if (/[0-9]/.test(password))                        score++;
    if (/[^A-Za-z0-9]/.test(password))                score++;

    if (score <= 1) {
      bar.className = 'strength-bar weak';
      label.textContent = 'Contraseña débil — agrega números y mayúsculas';
      label.style.color = 'var(--color-error)';
    } else if (score <= 3) {
      bar.className = 'strength-bar medium';
      label.textContent = 'Contraseña moderada — añade símbolos para mejorarla';
      label.style.color = 'var(--color-accent)';
    } else {
      bar.className = 'strength-bar strong';
      label.textContent = 'Contraseña fuerte ✓';
      label.style.color = '#22c55e';
    }
  }

  /* ============================================================
     FORMULARIO DE INICIO DE SESIÓN
  ============================================================ */
  document.getElementById('login-form').addEventListener('submit', function(e) {
    e.preventDefault();

    let valid = true;
    valid = validateEmail('login-email', 'login-email-error') && valid;
    valid = validateRequired('login-password', 'login-password-error', 'La contraseña es obligatoria.') && valid;

    if (!valid) return;

    // Simular envío — estado de carga
    const btn = document.getElementById('login-submit-btn');
    btn.textContent = 'Verificando…';
    btn.classList.add('loading');

    // Simulación de llamada a la API (timeout representa la petición al backend FastAPI)
    setTimeout(() => {
      btn.classList.remove('loading');
      btn.textContent = 'Iniciar Sesión';

      // Simulación de credenciales incorrectas para demostración de manejo de error
      const email    = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;

      if (email === 'demo@investai.com' && password === 'Demo1234!') {
        showAlert('login-alert', '¡Sesión iniciada correctamente! Redirigiendo al dashboard…', 'success');
      } else {
        showAlert('login-alert', 'Correo o contraseña incorrectos. Verifica tus credenciales e intenta de nuevo.', 'error');
      }
    }, 1600);
  });

  /* ============================================================
     FORMULARIO DE REGISTRO
  ============================================================ */
  document.getElementById('register-form').addEventListener('submit', function(e) {
    e.preventDefault();

    let valid = true;

    // Nombre completo
    valid = validateRequired('reg-name', 'reg-name-error', 'El nombre completo es obligatorio.') && valid;
    if (document.getElementById('reg-name').value.trim().split(' ').length < 2) {
      showFieldError('reg-name', 'reg-name-error', 'Ingresa tu nombre y apellido.');
      valid = false;
    }

    // Email
    valid = validateEmail('reg-email', 'reg-email-error') && valid;

    // Contraseña
    const password = document.getElementById('reg-password').value;
    if (!password) {
      showFieldError('reg-password', 'reg-password-error', 'La contraseña es obligatoria.');
      valid = false;
    } else if (password.length < 8) {
      showFieldError('reg-password', 'reg-password-error', 'La contraseña debe tener al menos 8 caracteres.');
      valid = false;
    }

    // Confirmar contraseña
    const confirm = document.getElementById('reg-confirm').value;
    if (!confirm) {
      showFieldError('reg-confirm', 'reg-confirm-error', 'Confirma tu contraseña.');
      valid = false;
    } else if (password !== confirm) {
      showFieldError('reg-confirm', 'reg-confirm-error', 'Las contraseñas no coinciden.');
      valid = false;
    }

    // Perfil de inversor
    const profileSelected = document.querySelector('input[name="investor-profile"]:checked');
    if (!profileSelected) {
      const profileError = document.getElementById('reg-profile-error');
      profileError.textContent = 'Selecciona tu perfil de inversor.';
      profileError.classList.add('visible');
      valid = false;
    }

    // Términos y condiciones
    const terms = document.getElementById('reg-terms');
    if (!terms.checked) {
      const termsError = document.getElementById('reg-terms-error');
      termsError.textContent = 'Debes aceptar los Términos y Condiciones para continuar.';
      termsError.classList.add('visible');
      valid = false;
    }

    if (!valid) return;

    // Simulación de envío
    const btn = document.getElementById('register-submit-btn');
    btn.textContent = 'Creando cuenta…';
    btn.classList.add('loading');

    setTimeout(() => {
      btn.classList.remove('loading');
      btn.textContent = 'Crear Cuenta';

      showAlert(
        'register-alert',
        '¡Cuenta creada exitosamente! Revisa tu correo para confirmar tu dirección antes de iniciar sesión.',
        'success'
      );

      // Limpiar formulario
      document.getElementById('register-form').reset();
      document.getElementById('strength-bar').className = 'strength-bar';
      document.getElementById('strength-label').textContent = '';
    }, 1800);
  });

  /* ============================================================
     FORMULARIO DE RECUPERACIÓN DE CONTRASEÑA
  ============================================================ */
  document.getElementById('recovery-form').addEventListener('submit', function(e) {
    e.preventDefault();

    const valid = validateEmail('recovery-email', 'recovery-email-error');
    if (!valid) return;

    const btn = document.getElementById('recovery-submit-btn');
    btn.textContent = 'Enviando…';
    btn.classList.add('loading');

    setTimeout(() => {
      btn.classList.remove('loading');
      btn.textContent = 'Enviar enlace';

      // Ocultar formulario y mostrar confirmación
      document.getElementById('recovery-form').style.display = 'none';
      document.getElementById('recovery-success').classList.add('visible');
    }, 1500);
  });

  /* ============================================================
     SIMULACIÓN DE INICIO CON GOOGLE
  ============================================================ */
  function handleGoogleLogin() {
    const btn = document.querySelector('.btn-secondary');
    btn.textContent = 'Conectando con Google…';
    btn.disabled = true;

    setTimeout(() => {
      btn.disabled = false;
      btn.innerHTML = `
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Continuar con Google
      `;
      showAlert('login-alert', 'La autenticación con Google requiere configuración del proveedor OAuth en el backend.', 'error');
    }, 1200);
  }

  /* ============================================================
     INICIALIZACIÓN — asegurar que la primera pantalla sea visible
  ============================================================ */
  document.addEventListener('DOMContentLoaded', () => {
    const activeScreen = document.querySelector('.screen.active');
    if (activeScreen) {
      activeScreen.style.opacity = '1';
      activeScreen.style.transform = 'translateY(0)';
    }
  });
</script>

