              <div class="profile-option">
                <input type="radio" name="investor-profile" id="profile-moderado" value="moderado" checked />
                <label for="profile-moderado">
                  <span class="profile-icon" aria-hidden="true">⚖️</span>
                  Moderado
                </label>
              </div>

              <div class="profile-option">
                <input type="radio" name="investor-profile" id="profile-agresivo" value="agresivo" />
                <label for="profile-agresivo">
                  <span class="profile-icon" aria-hidden="true">🚀</span>
                  Agresivo
                </label>
              </div>

            </div>
            <span class="form-error" id="reg-profile-error" role="alert"></span>
          </div>

          <!-- Términos y condiciones -->
          <div class="checkbox-group">
            <input
              type="checkbox"
              id="reg-terms"
              name="terms"
              aria-describedby="reg-terms-error"
            />
            <label for="reg-terms">
              Acepto los <a href="#" onclick="return false;">Términos y Condiciones</a>
              y la <a href="#" onclick="return false;">Política de Privacidad</a>.
              Entiendo que InvestAI no constituye asesoramiento financiero regulado.
            </label>
