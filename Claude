            </div>
            <span class="form-error" id="login-password-error" role="alert"></span>
          </div>

          <div class="forgot-link">
            <button type="button" class="link-btn" onclick="goToScreen('screen-recovery')" style="font-size:0.8rem;">
              ¿Olvidaste tu contraseña?
            </button>
          </div>

          <button type="submit" class="btn-primary" id="login-submit-btn">
            Iniciar Sesión
          </button>
        </form>

        <p class="form-footer">
          ¿Aún no tienes cuenta?
          <button type="button" class="link-btn" onclick="goToScreen('screen-register')">Crear cuenta</button>
        </p>

      </section>

      <!-- ======================================================
           PANTALLA 2: REGISTRO
      ====================================================== -->
      <section class="screen" id="screen-register" aria-label="Crear cuenta">

        <button type="button" class="back-link" onclick="goToScreen('screen-login')" aria-label="Volver al inicio de sesión">
          ← Volver
        </button>

        <div class="form-header">
          <p class="form-eyebrow">Nuevo usuario</p>
          <h2 class="form-title">Crear cuenta</h2>
          <p class="form-subtitle">Configura tu perfil de inversión y empieza a analizar mercados.</p>
        </div>

        <!-- Indicador de pasos visuales -->
        <div class="step-indicator" aria-hidden="true">
          <div class="step-dot active"></div>
          <div class="step-dot"></div>
          <div class="step-dot"></div>
        </div>

        <!-- Alerta de error global del registro -->
        <div class="alert" id="register-alert" role="alert"></div>

        <form id="register-form" novalidate>

          <!-- Nombre completo -->
          <div class="form-group">
            <label class="form-label" for="reg-name">Nombre completo</label>
            <input
              class="form-input"
              type="text"
              id="reg-name"
              name="name"
              placeholder="María García López"
              autocomplete="name"
              aria-describedby="reg-name-error"
            />
            <span class="form-error" id="reg-name-error" role="alert"></span>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label class="form-label" for="reg-email">Correo electrónico</label>
            <input
              class="form-input"
              type="email"
              id="reg-email"
              name="email"
              placeholder="analista@empresa.com"
              autocomplete="email"
              aria-describedby="reg-email-error"
            />
            <span class="form-error" id="reg-email-error" role="alert"></span>
          </div>

          <!-- Contraseña con barra de fortaleza -->
          <div class="form-group">
            <label class="form-label" for="reg-password">Contraseña</label>
            <div class="input-wrapper">
              <input
                class="form-input"
                type="password"
                id="reg-password"
                name="password"
                placeholder="Mínimo 8 caracteres"
                autocomplete="new-password"
                aria-describedby="reg-password-error"
                oninput="checkPasswordStrength(this.value)"
              />
              <button type="button" class="toggle-password" onclick="togglePassword('reg-password', this)" aria-label="Mostrar u ocultar contraseña">
                <svg id="eye-reg-password" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
            <!-- Barra de fortaleza -->
            <div class="strength-bar" id="strength-bar" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <p class="strength-label" id="strength-label" aria-live="polite"></p>
            <span class="form-error" id="reg-password-error" role="alert"></span>
          </div>

          <!-- Confirmar contraseña -->
          <div class="form-group">
            <label class="form-label" for="reg-confirm">Confirmar contraseña</label>
            <div class="input-wrapper">
              <input
                class="form-input"
                type="password"
                id="reg-confirm"
                name="confirm"
                placeholder="Repite tu contraseña"
                autocomplete="new-password"
                aria-describedby="reg-confirm-error"
              />
              <button type="button" class="toggle-password" onclick="togglePassword('reg-confirm', this)" aria-label="Mostrar u ocultar confirmación de contraseña">
                <svg id="eye-reg-confirm" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
            <span class="form-error" id="reg-confirm-error" role="alert"></span>
          </div>

          <!-- Selector visual de perfil de inversor -->
          <div class="form-group">
            <label class="form-label">Perfil de inversor</label>
            <div class="profile-selector" role="radiogroup" aria-label="Selecciona tu perfil de inversor">

              <div class="profile-option">
                <input type="radio" name="investor-profile" id="profile-conservador" value="conservador" />
                <label for="profile-conservador">
                  <span class="profile-icon" aria-hidden="true">🛡️</span>
                  Conservador
