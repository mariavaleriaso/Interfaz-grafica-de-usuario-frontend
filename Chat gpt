<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>InvestAI - Sistema Inteligente de Inversión</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Calibri, Inter, sans-serif;
    }

    :root{
        --primary:#1F3864;
        --accent:#C5961A;
        --white:#FFFFFF;
        --black:#000000;
        --error:#DC3545;
        --border:#D9D9D9;
    }

    body{
        min-height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        background:#FFFFFF;
        padding:20px;
    }

    .container{
        width:100%;
        max-width:480px;
    }

    .card{
        background:var(--white);
        border:1px solid var(--border);
        border-radius:16px;
        padding:32px;
        box-shadow:0 8px 25px rgba(0,0,0,0.08);
        position:relative;
        overflow:hidden;
    }

    .header{
        text-align:center;
        margin-bottom:28px;
    }

    .header h1{
        color:var(--primary);
        font-size:1.8rem;
        margin-bottom:8px;
    }

    .header p{
        color:#555;
        font-size:0.95rem;
        line-height:1.5;
    }

    .screen{
        display:none;
        opacity:0;
        transform:translateX(20px);
        transition:all 0.35s ease;
    }

    .screen.active{
        display:block;
        opacity:1;
        transform:translateX(0);
    }

    h2{
        color:var(--primary);
        margin-bottom:20px;
        text-align:center;
    }

    .form-group{
        margin-bottom:16px;
    }

    label{
        display:block;
        margin-bottom:6px;
        font-weight:600;
        color:var(--black);
    }

    input,
    select{
        width:100%;
        padding:12px;
        border:1px solid #CFCFCF;
        border-radius:8px;
        font-size:15px;
        transition:0.3s;
    }

    input:focus,
    select:focus{
        border-color:var(--primary);
        outline:none;
        box-shadow:0 0 0 3px rgba(31,56,100,0.15);
    }

    .btn{
        width:100%;
        padding:13px;
        border:none;
        border-radius:8px;
        cursor:pointer;
        font-size:15px;
        font-weight:600;
        transition:0.3s;
    }

    .btn-primary{
        background:var(--primary);
        color:white;
    }

    .btn-primary:hover{
        background:#162A4B;
    }

    .btn-google{
        margin-top:12px;
        background:#fff;
        border:1px solid #ccc;
        color:#333;
    }

    .btn-google:hover{
        background:#f5f5f5;
    }

    .links{
        text-align:center;
        margin-top:15px;
    }

    .links a{
        color:var(--accent);
        text-decoration:none;
        font-weight:600;
        cursor:pointer;
    }

    .links a:hover{
        text-decoration:underline;
    }

    .error{
        color:var(--error);
        font-size:13px;
        margin-top:4px;
    }

    .success{
        background:#EAF8EE;
        color:#198754;
        border:1px solid #B8E3C5;
        padding:12px;
        border-radius:8px;
        margin-top:15px;
        display:none;
    }

    .checkbox-group{
        display:flex;
        align-items:flex-start;
        gap:10px;
        margin-bottom:15px;
    }

    .checkbox-group input{
        width:auto;
        margin-top:3px;
    }

    .checkbox-group label{
        margin:0;
        font-size:14px;
        font-weight:normal;
    }

    .divider{
        text-align:center;
        margin:15px 0;
        color:#777;
    }

    @media(max-width:480px){

        .card{
            padding:22px;
        }

        .header h1{
            font-size:1.4rem;
        }

        h2{
            font-size:1.2rem;
        }
    }
</style>
</head>
<body>

<div class="container">

    <div class="card">

        <div class="header">
            <h1>InvestAI</h1>
            <p>
                Sistema Inteligente de Inversión<br>
                Plataforma de apoyo a decisiones financieras basada en
                Inteligencia Artificial y modelos predictivos.
            </p>
        </div>

        <!-- ================= LOGIN ================= -->
        <div id="loginScreen" class="screen active">

            <h2>Inicio de Sesión</h2>

            <div class="form-group">
                <label>Email</label>
                <input type="email" id="loginEmail">
                <div class="error" id="loginEmailError"></div>
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" id="loginPassword">
                <div class="error" id="loginPasswordError"></div>
            </div>

            <button class="btn btn-primary" onclick="login()">
                Iniciar Sesión
            </button>

            <button class="btn btn-google">
                Continuar con Google
            </button>

            <div class="links">
                <a onclick="showScreen('forgotScreen')">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>

            <div class="links">
                ¿No tienes cuenta?
                <a onclick="showScreen('registerScreen')">
                    Crear cuenta
                </a>
            </div>

        </div>

        <!-- ================= REGISTRO ================= -->
        <div id="registerScreen" class="screen">

            <h2>Registro</h2>

            <div class="form-group">
                <label>Nombre Completo</label>
                <input type="text" id="regName">
                <div class="error" id="regNameError"></div>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" id="regEmail">
                <div class="error" id="regEmailError"></div>
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" id="regPassword">
                <div class="error" id="regPasswordError"></div>
            </div>

            <div class="form-group">
                <label>Confirmar Contraseña</label>
                <input type="password" id="regConfirmPassword">
                <div class="error" id="regConfirmError"></div>
            </div>

            <div class="form-group">
                <label>Perfil de Inversor</label>
                <select id="investorProfile">
                    <option value="">Seleccione</option>
                    <option>Conservador</option>
                    <option>Moderado</option>
                    <option>Agresivo</option>
                </select>
                <div class="error" id="profileError"></div>
            </div>

            <div class="checkbox-group">
                <input type="checkbox" id="terms">
                <label>
                    Acepto los términos y condiciones del sistema.
                </label>
            </div>

            <div class="error" id="termsError"></div>

            <button class="btn btn-primary" onclick="register()">
                Crear Cuenta
            </button>

            <div class="links">
                ¿Ya tienes cuenta?
                <a onclick="showScreen('loginScreen')">
                    Iniciar sesión
                </a>
            </div>

        </div>

        <!-- ================= RECUPERAR ================= -->
        <div id="forgotScreen" class="screen">

            <h2>Recuperar Contraseña</h2>

            <div class="form-group">
                <label>Email</label>
                <input type="email" id="forgotEmail">
                <div class="error" id="forgotEmailError"></div>
            </div>

            <button class="btn btn-primary" onclick="recoverPassword()">
                Enviar Enlace
            </button>

            <div class="success" id="successMessage">
                Se ha enviado un enlace de recuperación a su correo electrónico.
            </div>

            <div class="links">
                <a onclick="showScreen('loginScreen')">
                    Volver al inicio de sesión
                </a>
            </div>

        </div>

    </div>

</div>

<script>

    // Expresión regular para validar emails
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    // Cambiar entre pantallas sin recargar
    function showScreen(screenId){

        const screens = document.querySelectorAll('.screen');

        screens.forEach(screen=>{
            screen.classList.remove('active');
        });

        setTimeout(()=>{
            document.getElementById(screenId)
                    .classList.add('active');
        },100);
    }

    // Limpiar mensajes de error
    function clearErrors(){
        document.querySelectorAll('.error').forEach(el=>{
            el.textContent='';
        });
    }

    // LOGIN
    function login(){

        clearErrors();

        let valid = true;

        const email = document.getElementById('loginEmail').value.trim();
        const password = document.getElementById('loginPassword').value.trim();

        if(email === ''){
            document.getElementById('loginEmailError').textContent =
            'Ingrese su email.';
            valid = false;
        }
        else if(!emailRegex.test(email)){
            document.getElementById('loginEmailError').textContent =
            'Formato de email inválido.';
            valid = false;
        }

        if(password === ''){
            document.getElementById('loginPasswordError').textContent =
            'Ingrese su contraseña.';
            valid = false;
        }

        if(valid){
            alert('Inicio de sesión válido. Conectar con backend.');
        }
    }

    // REGISTRO
    function register(){

        clearErrors();

        let valid = true;

        const name = document.getElementById('regName').value.trim();
        const email = document.getElementById('regEmail').value.trim();
        const pass = document.getElementById('regPassword').value;
        const confirm = document.getElementById('regConfirmPassword').value;
        const profile = document.getElementById('investorProfile').value;
        const terms = document.getElementById('terms').checked;

        if(name === ''){
            document.getElementById('regNameError').textContent =
            'Ingrese su nombre completo.';
            valid = false;
        }

        if(email === ''){
            document.getElementById('regEmailError').textContent =
            'Ingrese un email.';
            valid = false;
        }
        else if(!emailRegex.test(email)){
            document.getElementById('regEmailError').textContent =
            'Email inválido.';
            valid = false;
        }

        if(pass.length < 6){
            document.getElementById('regPasswordError').textContent =
            'La contraseña debe tener al menos 6 caracteres.';
            valid = false;
        }

        if(pass !== confirm){
            document.getElementById('regConfirmError').textContent =
            'Las contraseñas no coinciden.';
            valid = false;
        }

        if(profile === ''){
            document.getElementById('profileError').textContent =
            'Seleccione un perfil.';
            valid = false;
        }

        if(!terms){
            document.getElementById('termsError').textContent =
            'Debe aceptar los términos y condiciones.';
            valid = false;
        }

        if(valid){
            alert('Registro validado correctamente. Conectar con backend.');
        }
    }

    // RECUPERACIÓN
    function recoverPassword(){

        clearErrors();

        const email =
            document.getElementById('forgotEmail').value.trim();

        if(email === ''){
            document.getElementById('forgotEmailError').textContent =
            'Ingrese su email.';
            return;
        }

        if(!emailRegex.test(email)){
            document.getElementById('forgotEmailError').textContent =
            'Email inválido.';
            return;
        }

        document.getElementById('successMessage').style.display='block';
    }

</script>

</body>
</html>
